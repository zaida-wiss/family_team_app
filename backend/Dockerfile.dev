FROM node:22-alpine
WORKDIR /app

# Installera beroenden separat från källkoden så att Docker kan cacha
# node_modules-lagret — byggs bara om när package.json ändras
COPY package*.json ./
RUN npm ci

# Källkoden kopieras sist — ändringar här ogiltigförklarar inte npm ci-lagret
COPY . .

EXPOSE 3000
CMD ["npm", "run", "dev"]
