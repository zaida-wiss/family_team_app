MONGODB_URI=mongodb+srv://your-username:your-password@cluster0.xxxxx.mongodb.net/family-team-app
PORT=3000
FRONTEND_URL=https://your-frontend-url.onrender.com
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
CALENDAR_ENCRYPTION_MASTER_KEY=32 slumpmässiga bytes, base64 (generera med: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))") — ADR-0014, fält-kryptering av kalenderns title/notes
CRON_SECRET=change-me-cron-secret (delas med Render Cron Job för POST /api/admin/purge-expired-accounts)
RESEND_API_KEY=Din API-nyckel från Resend
EMAIL_FROM=Den avsändaradress du verifierat på Resend (eller lämna tomt för onboarding@resend.dev under testning)